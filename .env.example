# Copy this file to .env and fill in the values.
# In Vercel, set these as Project Environment Variables.

# --- Frontend (also hard-coded into index.html + app.html CONFIG blocks) ---
SUPABASE_URL=
SUPABASE_ANON_KEY=

# --- Serverless WhatsApp function (server-side only) ---
SUPABASE_SERVICE_ROLE_KEY=   # bypasses RLS; NEVER expose to the browser
OPENROUTER_API_KEY=          # from openrouter.ai → Keys (free account is enough)
WHATSAPP_TOKEN=              # Meta permanent access token
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=       # any string you choose for webhook verification
WHATSAPP_APP_SECRET=         # (optional) Meta App Secret to verify X-Hub-Signature-256
NEXT_PUBLIC_APP_URL=         # e.g. https://masrufe.vercel.app — sent as HTTP-Referer to OpenRouter
